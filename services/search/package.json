{
  "name": "@nordhem/search",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "load-wands": "tsx src/wands/load-cli.ts",
    "load-eval": "tsx src/eval/load-eval-cli.ts",
    "run-eval": "tsx src/eval/run-eval-cli.ts",
    "bench-modes": "tsx src/eval/bench-modes-cli.ts",
    "tune": "tsx src/eval/tune-cli.ts",
    "index-products": "tsx src/es/index-cli.ts",
    "index-shop": "tsx src/es/index-shop-cli.ts",
    "seed-synonyms": "tsx src/es/seed-synonyms-cli.ts",
    "reload-synonyms": "tsx src/es/reload-synonyms-cli.ts",
    "simulate-traffic": "tsx src/analytics/simulate-cli.ts",
    "aggregate-clicks": "tsx src/analytics/aggregate-cli.ts",
    "eval-affinity": "tsx src/eval/eval-affinity-cli.ts",
    "suggest-synonyms": "tsx src/analytics/suggest-cli.ts",
    "tunnel": "cloudflared tunnel --url http://localhost:3001"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.4.2",
    "@huggingface/transformers": "^4.2.0",
    "@nordhem/db": "workspace:*",
    "@nordhem/shared": "workspace:*",
    "fastify": "^5.8.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/elasticsearch": "^12.0.1",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/node": "^25.9.3",
    "testcontainers": "^12.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
